end)

-- Цикл анти АФК
task.spawn(function()
    while true do
        task.wait(14 * 60)
        if antiAfkEnabled then
            local character = player.Character
            if character and character:FindFirstChild("Humanoid") then
                character.Humanoid.Jump = true
            end
        end
    end
end)

